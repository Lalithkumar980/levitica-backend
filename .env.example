PORT=5001

# MongoDB — your connection string (never commit real credentials)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Auth — use a long random string in production (e.g. openssl rand -hex 32). DO NOT CHANGE in production once set.
JWT_SECRET=your-jwt-secret-change-in-production

# Optional — file upload limits (used for CSV import and document metadata; files can be stored in DB or locally)
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,doc,docx,mp3,mp4,xlsx,csv

# Optional — only if you add cloud storage later (not required when using MongoDB only)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# AWS_BUCKET_NAME=
# AWS_REGION=
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=
