PORT=5001

# Deploy (Vercel + Render): allow your live front-end origin(s). Also all *.vercel.app is allowed in code.
# FRONTEND_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://custom-domain.com

# MongoDB — one URI. Local, Atlas SRV, or Atlas direct (if SRV/DNS fails on your PC).
MONGODB_URI=mongodb://127.0.0.1:27017/myDatabase

# Atlas (SRV — needs working DNS for _mongodb._tcp... lookups):
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# Atlas (direct — if you see querySrv ECONNREFUSED: get shard hostnames from Atlas Connect or nslookup SRV;
# use one primary-eligible host, tls=true, authSource=admin, directConnection=true):
# MONGODB_URI=mongodb://<user>:<pass>@<shard00>.mongodb.net:27017/<db>?tls=true&authSource=admin&retryWrites=true&w=majority&directConnection=true

# Auth — use a long random string in production (e.g. openssl rand -hex 32). DO NOT CHANGE in production once set.
JWT_SECRET=your-jwt-secret-change-in-production

# Optional — file upload limits (used for CSV import and document metadata; files can be stored in DB or locally)
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,doc,docx,mp3,mp4,xlsx,csv

# --- Onboarding (invite + Google Drive) ---
# Public form URL base (link in email): must include /onboarding path if your SPA route is /onboarding
# ONBOARDING_FORM_BASE_URL=http://localhost:3000/onboarding
# ONBOARDING_INVITE_TTL_HOURS=168
# ONBOARDING_INVITE_SUBJECT=Complete your document verification
# ONBOARDING_MAX_FILES=50
# ONBOARDING_MAX_FILE_MB=25

# Email (Nodemailer). If SMTP is missing or wrong, send-invite returns 502 until fixed.
#
# Real SMTP (example: Gmail — use an App Password in Google Account → Security)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.address@gmail.com
# SMTP_PASS=your-16-char-app-password
# MAIL_FROM="Levitica Document Verification <your.address@gmail.com>"
#
# Local dev — no mailbox: API still returns 201 (no real email; see server logs)
# EMAIL_USE_JSON=true
#
# Local dev — keep invitation + return inviteUrl in JSON if SMTP fails (copy link to candidate)
# ONBOARDING_RETURN_INVITE_LINK_ON_EMAIL_FAILURE=true

# Google Drive — OAuth Web client + refresh token (see GOOGLE_DRIVE_SETUP.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5001/oauth2callback
# GOOGLE_REFRESH_TOKEN=
# Root folder in the token owner’s My Drive (created if missing)
# GOOGLE_DRIVE_ROOT_FOLDER=CandidateUploads

# Optional — generic authenticated upload limits (POST /api/upload)
# UPLOAD_MAX_FILES=20
# UPLOAD_MAX_FILE_MB=25

# Dev: log full email payload instead of sending (nodemailer jsonTransport)
# EMAIL_USE_JSON=true
